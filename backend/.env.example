NODE_ENV=development
PORT=3001

# Database (Railway injects DATABASE_URL automatically in production)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gustopro_gestionale

# JWT — change this to a 256-bit random string in production
JWT_SECRET=change_this_to_a_long_random_secret_string

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,https://gestione.gustopro.it

# DB Pool tuning (optional)
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=10000
DB_POOL_CONNECTION_TIMEOUT_MS=2000
